/**
 * 小程序壳视觉 Token — 紫色主题 #9966FF（首页与 Tab 统一）
 */
page {
  --color-bg: #ffffff;
  --color-surface: #ffffff;
  --color-border: #eeeeee;
  --color-text: #111111;
  --color-text-muted: #999999;
  --color-primary: #9966ff;
  --color-primary-dark: #7c3aed;
  --color-secondary: #a78bfa;
  --color-success: #22c55e;
  --color-warning: #f59e0b;
  --color-error-bg: #fef2f2;
  --color-error-text: #991b1b;
  --color-info: #8b5cf6;

  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-block: 16rpx;
  --radius-xl: 36rpx;
  --radius-pill: 9999rpx;

  --space-xs: 8rpx;
  --space-sm: 16rpx;
  --space-md: 32rpx;
  --space-lg: 48rpx;
  --space-xl: 64rpx;

  --shadow-card: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
  --shadow-soft: 0 2rpx 12rpx rgba(15, 23, 42, 0.04);

  background-color: var(--color-bg);
  color: var(--color-text);
  font-family: "PingFang SC", "Noto Sans SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

.cos-display {
  font-size: 52rpx;
  font-weight: 600;
  letter-spacing: -0.02em;
  line-height: 1.25;
  color: var(--color-text);
}

.cos-body {
  font-size: 28rpx;
}

.cos-meta {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.cos-data {
  font-family: "SF Mono", "Droid Sans Mono", "Roboto Mono", monospace;
  font-variant-numeric: tabular-nums;
}

.cos-code {
  font-family: "SF Mono", "Droid Sans Mono", monospace;
  font-size: 24rpx;
}

.cos-status-bar {
  background-color: var(--color-surface);
  border-left: 6rpx solid var(--color-info);
  padding: var(--space-sm) var(--space-md);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-soft);
}

.cos-status-bar--primary {
  border-left-color: var(--color-primary);
}

.cos-btn-primary {
  background-color: var(--color-primary) !important;
  color: #fff !important;
  border-radius: var(--radius-pill) !important;
  font-weight: 600;
  font-size: 30rpx;
  padding: 24rpx var(--space-md);
  border: none !important;
  box-shadow: 0 4rpx 16rpx rgba(153, 102, 255, 0.28);
}

.cos-btn-primary::after {
  border: none;
}

.cos-btn-secondary {
  background-color: var(--color-surface) !important;
  color: var(--color-primary-dark) !important;
  border: 2rpx solid var(--color-primary) !important;
  border-radius: var(--radius-pill) !important;
  font-weight: 600;
  font-size: 28rpx;
  padding: 20rpx var(--space-md);
}

.cos-btn-secondary::after {
  border: none;
}

.cos-link {
  color: var(--color-primary-dark);
  font-size: 28rpx;
  text-decoration: underline;
}

.cos-link.tap {
  display: inline-block;
  padding: 8rpx 0;
}

.cos-card {
  background-color: var(--color-surface);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-border);
  padding: var(--space-md);
  box-shadow: var(--shadow-card);
}

.cos-divider {
  height: 1rpx;
  background-color: var(--color-border);
  margin: var(--space-md) 0;
}

.cos-skeleton {
  padding: var(--space-md) 0;
}

.cos-skeleton-line {
  height: 32rpx;
  background-color: #e5e7eb;
  border-radius: var(--radius-sm);
  margin-bottom: var(--space-sm);
}

.cos-skeleton-line--short {
  width: 60%;
}

.cos-page-state {
  padding: var(--space-md);
  text-align: center;
}

.cos-page-state__retry {
  margin-top: var(--space-md);
}

.cos-tabular {
  font-variant-numeric: tabular-nums;
  font-family: "SF Mono", "Droid Sans Mono", "Roboto Mono", monospace;
}

/* 顶部搜索条（首页 / 规范） */
.cos-search-bar {
  display: flex;
  align-items: center;
  height: 72rpx;
  padding: 0 28rpx;
  background-color: var(--color-surface);
  border-radius: var(--radius-pill);
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-soft);
  color: var(--color-text-muted);
  font-size: 26rpx;
}

.cos-search-bar__icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

/* Tag：浅色底 + 主题字 */
.cos-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-sm);
  background-color: rgba(153, 102, 255, 0.14);
  color: var(--color-primary-dark);
  font-size: 24rpx;
}

.cos-tag--hot {
  background-color: rgba(236, 72, 153, 0.12);
  color: #db2777;
}

/* 吸底操作栏槽位 */
.cos-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 32rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid var(--color-border);
  box-shadow: 0 -4rpx 20rpx rgba(15, 23, 42, 0.04);
  z-index: 100;
}
