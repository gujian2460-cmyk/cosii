<view class="page">
  <block wx:if="{{loading}}">
    <view class="cos-skeleton">
      <view class="cos-skeleton-line"></view>
      <view class="cos-skeleton-line"></view>
    </view>
  </block>
  <block wx:elif="{{error}}">
    <view class="cos-page-state">
      <text class="cos-body">{{error.userTitle}}</text>
      <text wx:if="{{error.traceId}}" class="cos-code cos-meta" selectable="true">{{error.traceId}}</text>
      <button class="cos-btn-primary cos-page-state__retry" bindtap="refresh">重试</button>
    </view>
  </block>
  <block wx:elif="{{kind === 'service' && service}}">
    <view class="cos-card block">
      <text class="cos-body title">约妆订单</text>
      <text class="cos-meta line">订单号 {{service.service_order_id}}</text>
      <text class="cos-meta line">统一单 {{service.unified_order_id}}</text>
      <text class="cos-body line">状态 {{service.status_label}}</text>
      <text class="cos-meta line">定金 ¥{{service.depositYuan}} · 尾款 ¥{{service.finalYuan}}</text>
      <text class="cos-meta line warn" wx:if="{{service.holdNote}}">{{service.holdNote}}</text>
      <text class="cos-meta cta-hint" wx:if="{{ctaHint}}">{{ctaHint}}</text>
      <button
        wx:if="{{ctaKind !== 'none' && ctaLabel}}"
        class="cos-btn-primary cta-btn"
        bindtap="onPrimaryCtaTap"
        loading="{{payBusy}}"
        disabled="{{payBusy}}"
      >{{ctaLabel}}</button>
    </view>
  </block>
  <block wx:elif="{{kind === 'trade' && trade}}">
    <view class="cos-card block">
      <text class="cos-body title">闲置订单</text>
      <text class="cos-body line">{{trade.item_title}}</text>
      <text class="cos-meta line">订单号 {{trade.trade_order_id}}</text>
      <text class="cos-meta line">统一单 {{trade.unified_order_id}}</text>
      <text class="cos-body line">状态 {{trade.status_label}}</text>
      <text class="cos-meta line">金额 ¥{{trade.totalYuan}}</text>
      <text class="cos-meta cta-hint" wx:if="{{ctaHint}}">{{ctaHint}}</text>
      <button
        wx:if="{{ctaKind !== 'none' && ctaLabel && ctaKind !== 'redeem_handoff'}}"
        class="cos-btn-primary cta-btn"
        bindtap="onPrimaryCtaTap"
        loading="{{ctaKind === 'pay_trade' ? payBusy : actionBusy}}"
        disabled="{{payBusy || actionBusy}}"
      >{{ctaLabel}}</button>
      <block wx:if="{{showRedeem}}">
        <input
          class="redeem-input"
          type="text"
          placeholder="输入买家提货码"
          value="{{redeemInput}}"
          bindinput="onRedeemInput"
        />
        <button
          class="cos-btn-primary cta-btn"
          bindtap="onPrimaryCtaTap"
          loading="{{actionBusy}}"
          disabled="{{actionBusy}}"
        >{{ctaLabel}}</button>
      </block>
    </view>
  </block>
</view>
