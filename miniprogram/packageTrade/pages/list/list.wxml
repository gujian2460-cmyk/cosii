<view class="page">
  <text class="lead cos-body">在售列表</text>

  <view class="segmented cos-meta">
    <view
      class="seg-item {{activeCategory === item.id ? 'seg-item--on' : ''}}"
      wx:for="{{categories}}"
      wx:key="id"
      bindtap="onCategoryTap"
      data-category="{{item.id}}"
    >{{item.label}}</view>
  </view>

  <block wx:if="{{loading}}">
    <view class="cos-skeleton">
      <view class="cos-skeleton-line"></view>
      <view class="cos-skeleton-line"></view>
    </view>
  </block>
  <block wx:elif="{{error}}">
    <view class="cos-page-state">
      <text class="cos-body">{{error.userTitle}}</text>
      <button class="cos-btn-primary back" bindtap="refresh">重试</button>
    </view>
  </block>
  <block wx:elif="{{empty}}">
    <view class="cos-page-state">
      <text class="cos-body">暂无在售商品</text>
      <button class="cos-btn-primary back" bindtap="goBack">返回</button>
    </view>
  </block>
  <block wx:else>
    <view class="cos-card item" wx:for="{{items}}" wx:key="item_id">
      <text class="title cos-body">{{item.title}}</text>
      <text class="cos-meta line">{{item.category}}</text>
      <text class="cos-body cos-tabular line">¥{{item.priceYuan}}</text>
      <button
        class="cos-btn-primary buy-btn"
        bindtap="onBuyTap"
        data-item-id="{{item.item_id}}"
        loading="{{creatingOrderId === item.item_id}}"
      >立即下单</button>
    </view>

    <view class="load-more cos-meta" wx:if="{{nextCursor}}">
      <text wx:if="{{loadingMore}}">加载中…</text>
      <text wx:else>上拉加载更多</text>
    </view>
  </block>
</view>
