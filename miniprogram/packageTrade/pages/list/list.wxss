.page {
  min-height: 100vh;
  padding: 32rpx 32rpx 120rpx;
  box-sizing: border-box;
}

.lead {
  display: block;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.back {
  width: 100%;
}

.segmented {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}

.seg-item {
  padding: 12rpx 28rpx;
  border-radius: var(--radius-pill);
  border: 2rpx solid var(--color-border);
  background-color: var(--color-surface);
  color: var(--color-text-muted);
}

.seg-item--on {
  color: var(--color-primary-dark);
  border-color: var(--color-primary);
  background-color: rgba(168, 85, 247, 0.1);
  font-weight: 600;
}

.item {
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-weight: 600;
}

.line {
  display: block;
  margin-top: 8rpx;
}

.buy-btn {
  margin-top: 24rpx;
}

.load-more {
  text-align: center;
  padding: 16rpx 0 8rpx;
  opacity: 0.8;
}

.load-more-retry {
  text-align: center;
  padding: 0 0 40rpx;
}

.load-more-retry__btn {
  min-width: 200rpx;
}
