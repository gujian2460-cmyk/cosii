.page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
}

.lead {
  display: block;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.back {
  width: 100%;
}

.segmented {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}

.seg-item {
  padding: 12rpx 24rpx;
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
  background-color: var(--color-surface);
}

.seg-item--on {
  color: var(--color-primary);
  border-color: var(--color-primary);
}

.item {
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-weight: 600;
}

.line {
  display: block;
  margin-top: 8rpx;
}

.buy-btn {
  margin-top: 24rpx;
}

.load-more {
  text-align: center;
  padding: 16rpx 0 40rpx;
  opacity: 0.8;
}
