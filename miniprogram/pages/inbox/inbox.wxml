<view class="page">
  <view class="head cos-card">
    <text class="head-title">消息中心</text>
    <text class="head-sub">及时查看订单与系统提醒</text>
    <view class="head-count-wrap">
      <text class="head-count-label">最近通知</text>
      <text class="head-count cos-tabular">{{totalCount}}</text>
    </view>
  </view>

  <scroll-view class="filter-scroll" scroll-x enable-flex="{{true}}" show-scrollbar="{{false}}">
    <view class="filter-inner">
      <view
        wx:for="{{filters}}"
        wx:key="id"
        class="filter-pill {{activeFilter === item.id ? 'filter-pill--on' : ''}}"
        bindtap="onFilterTap"
        data-id="{{item.id}}"
      >
        {{item.label}}
      </view>
    </view>
  </scroll-view>

  <block wx:if="{{loading}}">
    <view class="cos-skeleton">
      <view class="cos-skeleton-line"></view>
      <view class="cos-skeleton-line"></view>
      <view class="cos-skeleton-line cos-skeleton-line--short"></view>
    </view>
  </block>
  <block wx:elif="{{error}}">
    <view class="cos-page-state">
      <text class="cos-body">{{error.userTitle}}</text>
      <text wx:if="{{error.retryPolicy}}" class="cos-meta state-hint">{{error.retryPolicy}}</text>
      <view wx:if="{{error.traceId}}" class="trace-row">
        <text class="cos-code cos-meta trace-label">追踪 ID</text>
        <text class="cos-code cos-meta trace-val" selectable="true">{{error.traceId}}</text>
        <text class="cos-link tap trace-copy" bindtap="onCopyTraceTap">复制</text>
      </view>
      <button class="cos-btn-primary cos-page-state__retry" bindtap="refresh">重试</button>
    </view>
  </block>
  <block wx:else>
    <block wx:if="{{emptyReason === 'list'}}">
      <view class="empty">
        <text class="empty-title">暂无通知</text>
        <text class="empty-sub cos-meta">有新订单或系统提醒时会出现在这里</text>
        <view class="cos-link tap empty-link" bindtap="goOrdersTab">去订单看看</view>
      </view>
    </block>
    <block wx:elif="{{emptyReason === 'filter'}}">
      <view class="empty">
        <text class="empty-title">暂无匹配通知</text>
        <text class="empty-sub cos-meta">换个筛选看看，或去订单页查看完整进度</text>
        <view class="cos-link tap empty-link" bindtap="goOrdersTab">去订单看看</view>
      </view>
    </block>
    <block wx:else>
      <view
        class="cos-card row"
        wx:for="{{visibleNotifications}}"
        wx:key="notification_id"
        bindtap="onNotifyTap"
        data-unified-id="{{item.unified_order_id}}"
        data-order-type="{{item.order_type}}"
        data-domain-id="{{item.domain_order_id}}"
      >
        <view class="row-main">
          <view class="row-head">
            <text class="type-tag">{{item.typeLabel}}</text>
            <text class="time cos-meta">{{item.time}}</text>
          </view>
          <text class="cos-body row-title">{{item.title}}</text>
          <text class="cos-meta row-sub">{{item.subtitle}}</text>
        </view>
        <text class="arrow">›</text>
      </view>
    </block>
  </block>
</view>
