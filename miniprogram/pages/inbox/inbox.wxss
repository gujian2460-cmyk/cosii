.page {
  padding: 32rpx;
  padding-bottom: calc(32rpx + 200rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  box-sizing: border-box;
  background-color: #f6f5fb;
}

.head {
  margin-bottom: 20rpx;
  background: linear-gradient(135deg, #9966ff, #7c3aed);
  border: none;
}

.head-title {
  display: block;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
}

.head-sub {
  display: block;
  color: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
  margin-top: 8rpx;
}

.head-count-wrap {
  margin-top: 20rpx;
  display: flex;
  flex-direction: row;
  align-items: baseline;
  justify-content: space-between;
}

.head-count-label {
  color: rgba(255, 255, 255, 0.85);
  font-size: 24rpx;
}

.head-count {
  color: #ffffff;
  font-size: 48rpx;
  font-weight: 700;
}

.filter-scroll {
  width: 100%;
  margin-bottom: 16rpx;
}

.filter-inner {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: 14rpx;
  padding: 2rpx 0 4rpx;
}

.filter-pill {
  flex-shrink: 0;
  border-radius: var(--radius-pill);
  border: 2rpx solid #c4b5fd;
  color: #7c3aed;
  background-color: #ffffff;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  box-sizing: border-box;
}

.filter-pill--on {
  border-color: transparent;
  color: #ffffff;
  font-weight: 700;
  background: linear-gradient(135deg, #9966ff, #7c3aed);
  box-shadow: 0 4rpx 14rpx rgba(124, 58, 237, 0.35);
}

.state-hint {
  display: block;
  margin-top: 12rpx;
  line-height: 1.5;
}

.trace-row {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 12rpx;
  background-color: rgba(17, 24, 39, 0.04);
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx 16rpx;
}

.trace-label {
  flex-shrink: 0;
}

.trace-val {
  flex: 1;
  min-width: 0;
  word-break: break-all;
}

.trace-copy {
  flex-shrink: 0;
  font-size: 26rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 14rpx;
  background-color: #ffffff;
}

.row-main {
  flex: 1;
  min-width: 0;
}

.row-head {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.type-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background-color: rgba(153, 102, 255, 0.14);
  color: #7c3aed;
  font-size: 22rpx;
}

.row-title {
  display: block;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.row-sub {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.5;
}

.empty {
  margin-top: 64rpx;
  text-align: center;
  padding: 0 20rpx;
}

.empty-title {
  display: block;
  color: #374151;
  font-size: 30rpx;
  font-weight: 600;
}

.empty-sub {
  display: block;
  margin-top: 10rpx;
}

.empty-link {
  margin-top: 24rpx;
  display: inline-block;
}

.time {
  margin-left: 14rpx;
}

.arrow {
  flex-shrink: 0;
  margin-left: 16rpx;
  margin-top: 4rpx;
  color: #b1b5c3;
  font-size: 36rpx;
  line-height: 1;
}
