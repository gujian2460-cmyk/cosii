/* 首页：紫色主题 #9966FF / 白底 */

.home-page {
  width: 100%;
  min-height: 100vh;
  background-color: #ffffff;
}

.home-header {
  position: sticky;
  top: 0;
  z-index: 200;
  background-color: #ffffff;
  box-sizing: border-box;
}

.home-header__status {
  width: 100%;
}

.home-header__row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding-left: 24rpx;
  gap: 16rpx;
  box-sizing: border-box;
}

.home-search-capsule {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  padding: 0 28rpx;
  margin-right: 0;
  background-color: #eceef2;
  border-radius: var(--radius-pill);
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.home-recent-expo {
  flex-shrink: 0;
  padding: 0 20rpx;
  height: 56rpx;
  line-height: 56rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-primary-dark);
  background-color: #f5f3ff;
  border-radius: var(--radius-pill);
  border: 1rpx solid rgba(153, 102, 255, 0.35);
}

.home-search-capsule__ph {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.home-scroll {
  width: 100%;
  box-sizing: border-box;
}

/* scroll-into-view 锚点：无占位间隙 */
.home-scroll-top-anchor {
  width: 100%;
  height: 1px;
  font-size: 0;
  line-height: 0;
  opacity: 0;
  pointer-events: none;
}

.home-banner-wrap {
  padding: 0 24rpx;
  margin-top: 8rpx;
}

.home-banner-stack {
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
}

.home-banner-swiper {
  height: 280rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.home-banner-slide {
  height: 100%;
  border-radius: 16rpx;
  box-sizing: border-box;
  position: relative;
}

.home-banner-slide--ph {
  background-color: #f3f4f6;
}

.home-dots {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
  gap: 10rpx;
}

.home-dots--inset {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 28rpx;
  z-index: 2;
  pointer-events: none;
}

.home-dots__item {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #d0d0d0;
}

.home-dots__item--on {
  width: 24rpx;
  border-radius: 6rpx;
  background-color: #9966ff;
}

.home-king-card {
  margin: 16rpx 24rpx 0;
  background-color: #ffffff;
  border-radius: 16rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--color-border);
  padding: 36rpx 12rpx 32rpx;
  box-sizing: border-box;
}

.home-king {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  width: 100%;
  box-sizing: border-box;
  gap: 4rpx;
}

.home-king--fixed {
  padding: 0 8rpx;
}

.home-king__item {
  flex: 1;
  min-width: 0;
  max-width: 140rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.home-king__circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #9966ff;
  background-color: #ede9fe;
  margin-bottom: 12rpx;
}

.home-king__label {
  font-size: 20rpx;
  color: #111111;
  text-align: center;
  line-height: 1.2;
  margin-top: 4rpx;
}

.home-feed-head--between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding-top: 28rpx;
}

.home-feed-head--featured .home-feed-head__titles {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 12rpx 16rpx;
  flex: 1;
  min-width: 0;
}

.home-feed-head__more {
  flex-shrink: 0;
  font-size: 26rpx;
  color: var(--color-primary);
  font-weight: 500;
  padding-left: 16rpx;
}

.home-char-row {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  margin-bottom: 8rpx;
}

.home-char-scroll {
  white-space: nowrap;
}

.home-char-scroll--flex {
  flex: 1;
  min-width: 0;
  width: auto;
  height: 220rpx;
  white-space: nowrap;
}

.home-char-inner {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 0 20rpx 16rpx;
  gap: 24rpx;
  box-sizing: border-box;
}

.home-char-chip {
  flex-shrink: 0;
  width: 132rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.home-char-ava {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(153, 102, 255, 0.15);
}

.home-char-ava--ph {
  background-color: #ede9fe;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.home-char-ava__dim {
  font-size: 16rpx;
  color: rgba(153, 102, 255, 0.55);
  font-weight: 500;
}

.home-char-name {
  margin-top: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #111111;
}

.home-char-work {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
  text-align: center;
  width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.feat-card {
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.feat-card__media {
  position: relative;
  width: 100%;
  min-height: 260rpx;
  border-radius: 16rpx;
}

.feat-card__media--gray {
  background-color: #e5e7eb;
}

/* 瀑布流：大 / 小卡片交错（高度差明显） */
.feat-card__media--large {
  min-height: 360rpx;
}

.feat-card__media--small {
  min-height: 220rpx;
}

.feat-card__grad {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 56rpx 16rpx 16rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.62) 100%);
  border-radius: 0 0 16rpx 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.feat-card__line {
  font-size: 24rpx;
  font-weight: 600;
  color: #ffffff;
  line-height: 1.35;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.home-feed-head {
  padding: 32rpx 20rpx 16rpx;
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 16rpx;
}

.home-feed-head__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111111;
}

.home-feed-head__sub {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.home-masonry {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 0 20rpx 32rpx;
  gap: 20rpx;
}

/* 精选区为末段内容时收紧底边距（原「发现」已移除） */
.home-masonry--tail {
  padding-bottom: 16rpx;
}

.home-masonry__col {
  flex: 1;
  min-width: 0;
}

.home-foot {
  padding: 24rpx 32rpx 48rpx;
  border-top: 1rpx solid var(--color-border);
}

.home-foot__t {
  font-size: 24rpx;
  color: var(--color-text-muted);
  display: block;
}

.home-foot__trace {
  font-size: 22rpx;
  color: #bbbbbb;
  margin-top: 8rpx;
  word-break: break-all;
}

.home-foot-spacer {
  height: calc(200rpx + env(safe-area-inset-bottom));
}
