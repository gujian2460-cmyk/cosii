<view class="page">
  <view class="hero">
    <text class="hero-title cos-display">Cosii</text>
    <text class="hero-sub cos-meta">可信成交 · 约妆与闲置</text>
  </view>

  <view class="trust-bar cos-status-bar">
    <text class="trust-text cos-body">资金托管与档期占位；订单状态以「订单」Tab 详情为准。</text>
  </view>

  <view class="cta-block">
    <button class="cos-btn-primary cta-main" bindtap="onPrimaryCta">逛在售</button>
    <view class="cta-secondary-wrap">
      <view class="cos-link tap" bindtap="onSecondaryLink">约妆娘</view>
      <text class="cos-meta secondary-hint">（档期与定金流程即将接入）</text>
    </view>
  </view>

  <view class="secondary-list">
    <view class="row cos-body" bindtap="onRowTap" data-hint="热门装扮">
      <text>热门装扮</text>
      <text class="cos-meta">›</text>
    </view>
    <view class="row cos-body" bindtap="onRowTap" data-hint="认证妆娘">
      <text>认证妆娘</text>
      <text class="cos-meta">›</text>
    </view>
  </view>

  <view class="feed-placeholder cos-meta" wx:if="{{showFeedHint}}">
    内容推荐占位（P2）
  </view>

  <view class="api-strip cos-meta" wx:if="{{healthLabel}}">
    <text>{{healthLabel}}</text>
    <text wx:if="{{healthTrace}}" class="cos-code trace" selectable="true">{{healthTrace}}</text>
  </view>
</view>
