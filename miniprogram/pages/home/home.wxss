.page {
  min-height: 100vh;
  padding: 48rpx 32rpx 120rpx;
}

.hero {
  margin-bottom: 40rpx;
}

.hero-title {
  display: block;
  color: var(--color-text);
}

.hero-sub {
  display: block;
  margin-top: 12rpx;
}

.trust-bar {
  margin-bottom: 48rpx;
}

.trust-text {
  color: var(--color-text-muted);
}

.cta-block {
  margin-bottom: 48rpx;
}

.cta-main {
  width: 100%;
  margin-bottom: 24rpx;
}

.cta-secondary-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
}

.secondary-hint {
  margin-left: 0;
}

.secondary-list {
  background-color: var(--color-surface);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--color-border);
  overflow: hidden;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.row:last-child {
  border-bottom: none;
}

.feed-placeholder {
  margin-top: 40rpx;
  padding: 24rpx;
  text-align: center;
  opacity: 0.7;
}

.api-strip {
  margin-top: 48rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--color-border);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.trace {
  word-break: break-all;
  color: var(--color-text-muted);
}
