/* 首页：品牌 #D878A0 / 底 #F5F6F8 — 与 app.wxss 变量一致 */

.home-page {
  width: 100%;
  min-height: 100vh;
  background-color: var(--color-bg);
}

.home-header {
  position: sticky;
  top: 0;
  z-index: 200;
  background-color: var(--color-bg);
  box-sizing: border-box;
}

.home-header__status {
  width: 100%;
}

.home-header__row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding-left: 24rpx;
  box-sizing: border-box;
}

.home-loc {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-shrink: 0;
  max-width: 200rpx;
  margin-right: 16rpx;
}

.home-loc__icon {
  font-size: 26rpx;
  margin-right: 4rpx;
}

.home-loc__text {
  font-size: 24rpx;
  color: #111111;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.home-search-capsule {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  padding: 0 28rpx;
  background-color: #eceef2;
  border-radius: var(--radius-pill);
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.home-search-capsule__ph {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.home-scroll {
  width: 100%;
  box-sizing: border-box;
}

.home-banner-wrap {
  padding: 0 24rpx;
  margin-top: 8rpx;
}

.home-banner-swiper {
  height: 280rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.home-banner-slide {
  height: 100%;
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.home-banner-slide__k {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.55);
  margin-bottom: 8rpx;
}

.home-banner-slide__t {
  font-size: 32rpx;
  font-weight: 700;
  color: #111111;
  line-height: 1.3;
}

.home-dots {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
}

.home-dots__item {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #d0d0d0;
}

.home-dots__item--on {
  width: 24rpx;
  border-radius: 6rpx;
  background-color: #d878a0;
}

.home-king {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  padding: 40rpx 32rpx 8rpx;
  background-color: transparent;
}

.home-king__item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.home-king__circle {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.home-king__circle--1 {
  background: linear-gradient(145deg, #d878a0, #e8a0bc);
}

.home-king__circle--2 {
  background: linear-gradient(145deg, #c45d88, #d878a0);
}

.home-king__circle--3 {
  background: linear-gradient(145deg, #9b6b86, #d878a0);
}

.home-king__circle--4 {
  background: linear-gradient(145deg, #d878a0, #f0b8cc);
}

.home-king__label {
  font-size: 24rpx;
  color: #111111;
  text-align: center;
}

.home-feed-head {
  padding: 32rpx 20rpx 16rpx;
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 16rpx;
}

.home-feed-head__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111111;
}

.home-feed-head__sub {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.home-masonry {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 0 20rpx 32rpx;
  gap: 20rpx;
}

.home-masonry__col {
  flex: 1;
  min-width: 0;
}

.feed-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.feed-card__media {
  width: 100%;
  overflow: hidden;
}

.feed-card__img {
  width: 100%;
  display: block;
  height: 320rpx;
  border-top-left-radius: 16rpx;
  border-top-right-radius: 16rpx;
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
}

.feed-card__img--ph {
  height: 280rpx;
}

.feed-card__body {
  padding: 16rpx 16rpx 20rpx;
}

.feed-card__title {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  font-size: 28rpx;
  font-weight: 600;
  color: #111111;
  line-height: 1.4;
}

.feed-conv {
  margin-top: 12rpx;
  padding: 10rpx 14rpx;
  border-radius: 8rpx;
  align-self: flex-start;
}

.feed-conv__text {
  font-size: 24rpx;
  font-weight: 500;
}

.feed-conv--product {
  background-color: #fff0f5;
}

.feed-conv--product .feed-conv__text {
  color: #b03060;
}

.feed-conv--booking {
  background-color: #f3e8ff;
}

.feed-conv--booking .feed-conv__text {
  color: #6b21a8;
}

.feed-card__foot {
  margin-top: 16rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.feed-card__ava {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feed-card__ava-img {
  width: 100%;
  height: 100%;
}

.feed-card__ava-t {
  font-size: 18rpx;
  color: #666666;
}

.feed-card__nick {
  margin-left: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-muted);
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.feed-card__v {
  margin-left: 8rpx;
  flex-shrink: 0;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: linear-gradient(145deg, #f59e0b, #fbbf24);
  color: #fff;
  font-size: 18rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.home-foot {
  padding: 24rpx 32rpx 48rpx;
  border-top: 1rpx solid var(--color-border);
}

.home-foot__t {
  font-size: 24rpx;
  color: var(--color-text-muted);
  display: block;
}

.home-foot__trace {
  font-size: 22rpx;
  color: #bbbbbb;
  margin-top: 8rpx;
  word-break: break-all;
}

.home-foot-spacer {
  height: calc(24rpx + env(safe-area-inset-bottom));
}
