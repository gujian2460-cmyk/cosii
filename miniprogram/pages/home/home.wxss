.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 120rpx;
  box-sizing: border-box;
}

.home-search {
  margin-bottom: 28rpx;
}

.home-search-placeholder {
  color: var(--color-text-muted);
  font-size: 26rpx;
}

.banner {
  height: 220rpx;
  margin-bottom: 36rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.banner-slide {
  height: 100%;
  padding: 32rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.banner-slide--a {
  background: linear-gradient(135deg, #e9d5ff 0%, #fce7f3 50%, #fff 100%);
}

.banner-slide--b {
  background: linear-gradient(135deg, #ddd6fe 0%, #fbcfe8 45%, #fff 100%);
}

.banner-kicker {
  margin-bottom: 8rpx;
  color: var(--color-primary-dark);
}

.banner-title {
  font-weight: 600;
  font-size: 30rpx;
}

.king-grid {
  display: flex;
  justify-content: space-between;
  margin-bottom: 40rpx;
  padding: 8rpx 0;
}

.king-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.king-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.king-icon--buy {
  background: linear-gradient(145deg, #a855f7, #ec4899);
}

.king-icon--book {
  background: linear-gradient(145deg, #8b5cf6, #d946ef);
}

.king-icon--pub {
  background: linear-gradient(145deg, #c084fc, #f472b6);
}

.king-icon--order {
  background: linear-gradient(145deg, #7c3aed, #e879f9);
}

.king-icon--find {
  background: linear-gradient(145deg, #6366f1, #a78bfa);
}

.king-label {
  font-size: 22rpx;
}

.section-head {
  margin-bottom: 16rpx;
}

.row-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.section-title {
  font-weight: 600;
}

.event-scroll {
  white-space: nowrap;
  width: 100%;
  margin-bottom: 40rpx;
}

.event-card {
  display: inline-block;
  vertical-align: top;
  width: 320rpx;
  margin-right: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.event-card--alt {
  background: linear-gradient(180deg, #faf5ff 0%, #fff 100%);
}

.event-name {
  display: block;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.event-meta {
  display: block;
  white-space: normal;
}

.waterfall-preview {
  display: flex;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.waterfall-col {
  flex: 1;
  min-width: 0;
}

.preview-card {
  margin-bottom: 16rpx;
  padding: 0;
  overflow: hidden;
}

.preview-cover {
  height: 180rpx;
  width: 100%;
}

.preview-cover--1 {
  background: linear-gradient(160deg, #fae8ff, #fbcfe8);
}

.preview-cover--2 {
  background: linear-gradient(160deg, #e9d5ff, #cffafe);
  height: 240rpx;
}

.preview-cover--3 {
  background: linear-gradient(160deg, #fce7f3, #ddd6fe);
  height: 200rpx;
}

.preview-cover--4 {
  background: linear-gradient(160deg, #ede9fe, #fecdd3);
}

.preview-title {
  display: block;
  padding: 16rpx 16rpx 0;
  font-size: 26rpx;
  font-weight: 600;
}

.preview-card .cos-tag,
.preview-price {
  margin: 12rpx 16rpx 16rpx;
  display: inline-block;
}

.hero-foot {
  margin: 24rpx 0 32rpx;
}

.hero-brand {
  display: block;
  color: var(--color-primary-dark);
}

.hero-sub {
  display: block;
  margin-top: 12rpx;
}

.trust-bar {
  margin-bottom: 40rpx;
}

.trust-text {
  color: var(--color-text-muted);
}

.cta-block {
  margin-bottom: 40rpx;
}

.cta-main {
  width: 100%;
  margin-bottom: 24rpx;
}

.cta-secondary-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
}

.secondary-hint {
  margin-left: 0;
}

.secondary-list {
  overflow: hidden;
  padding: 0;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.row:last-child {
  border-bottom: none;
}

.feed-placeholder {
  margin-top: 24rpx;
  padding: 24rpx;
  text-align: center;
  opacity: 0.75;
}

.api-strip {
  margin-top: 40rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--color-border);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.trace {
  word-break: break-all;
  color: var(--color-text-muted);
}
