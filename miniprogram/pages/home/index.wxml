<view class="home-page" style="--safe-bottom: env(safe-area-inset-bottom);">
  <!-- 1. 沉浸式头部：避让胶囊 + 顶栏安全区 -->
  <view class="home-header" style="height: {{navBarHeightPx}}px;">
    <view class="home-header__status" style="height: {{statusBarHeight}}px;"></view>
    <view
      class="home-header__row"
      style="height: {{headerRowHeightPx}}px; padding-right: {{headerRightSpacePx}}px;"
    >
      <view class="home-search-capsule" bindtap="onSearchTap">
        <text class="home-search-capsule__ph">搜商品，如：Cos服</text>
      </view>
      <view class="home-recent-expo" bindtap="onRecentExpoTap">最近漫展</view>
    </view>
  </view>

  <scroll-view
    scroll-y
    class="home-scroll"
    style="height: {{scrollHeightPx}}px;"
    enable-back-to-top="{{true}}"
  >
    <!-- 2. 精选活动轮播（非通栏） -->
    <view class="home-banner-wrap">
      <swiper
        class="home-banner-swiper"
        circular
        autoplay
        interval="4800"
        duration="400"
        bindchange="onBannerChange"
        current="{{bannerCurrent}}"
      >
        <swiper-item wx:for="{{bannerSlides}}" wx:key="id">
          <view class="home-banner-slide" style="background: {{item.bg}};">
            <text class="home-banner-slide__k">{{item.kicker}}</text>
            <text class="home-banner-slide__t">{{item.title}}</text>
          </view>
        </swiper-item>
      </swiper>
      <view class="home-dots">
        <view
          wx:for="{{bannerSlides}}"
          wx:for-index="idx"
          wx:key="id"
          class="home-dots__item {{bannerCurrent === idx ? 'home-dots__item--on' : ''}}"
        />
      </view>
    </view>

    <!-- 3. 金刚区：5 项（对标设计稿） -->
    <scroll-view class="home-king-scroll" scroll-x>
      <view class="home-king home-king--5">
        <view class="home-king__item" bindtap="onKingTap" data-action="yi">
          <view class="home-king__circle home-king__circle--1">衣</view>
          <text class="home-king__label">COS服装</text>
        </view>
        <view class="home-king__item" bindtap="onKingTap" data-action="fa">
          <view class="home-king__circle home-king__circle--2">发</view>
          <text class="home-king__label">假发</text>
        </view>
        <view class="home-king__item" bindtap="onKingTap" data-action="zhuang">
          <view class="home-king__circle home-king__circle--3">妆</view>
          <text class="home-king__label">平时装造</text>
        </view>
        <view class="home-king__item" bindtap="onKingTap" data-action="zhou">
          <view class="home-king__circle home-king__circle--4">周</view>
          <text class="home-king__label">周边</text>
        </view>
        <view class="home-king__item" bindtap="onKingTap" data-action="zhan">
          <view class="home-king__circle home-king__circle--5">展</view>
          <text class="home-king__label">漫展约妆</text>
        </view>
      </view>
    </scroll-view>

    <view class="home-feed-head home-feed-head--tight">
      <text class="home-feed-head__title">热门角色</text>
      <text class="home-feed-head__sub">左右滑动</text>
    </view>
    <scroll-view class="home-char-scroll" scroll-x>
      <view class="home-char-inner">
        <view
          wx:for="{{characters}}"
          wx:key="id"
          class="home-char-chip"
          bindtap="onCharacterTap"
          data-name="{{item.name}}"
        >
          <view class="home-char-ava" style="background-color: {{item.coverColor}};"></view>
          <text class="home-char-name">{{item.name}}</text>
          <text class="home-char-work">{{item.workTitle}}</text>
        </view>
      </view>
    </scroll-view>

    <view class="home-feed-head">
      <text class="home-feed-head__title">精选返图</text>
      <text class="home-feed-head__sub">图底叠字 · 点赞</text>
    </view>
    <view class="home-masonry">
      <view class="home-masonry__col">
        <block wx:for="{{featLeft}}" wx:key="id">
          <view
            class="feat-card"
            bindtap="onFeaturedTap"
            data-keyword="{{item.characterName}}"
          >
            <view class="feat-card__media" style="background-color: {{item.coverColor}};">
              <view class="feat-card__grad">
                <text class="feat-card__char">{{item.characterName}}</text>
                <text class="feat-card__sub">{{item.title}}</text>
                <view class="feat-card__row">
                  <text class="feat-card__auth">{{item.author}}</text>
                  <text class="feat-card__like">{{item.likeCount}} 喜欢</text>
                </view>
              </view>
            </view>
          </view>
        </block>
      </view>
      <view class="home-masonry__col">
        <block wx:for="{{featRight}}" wx:key="id">
          <view
            class="feat-card"
            bindtap="onFeaturedTap"
            data-keyword="{{item.characterName}}"
          >
            <view class="feat-card__media" style="background-color: {{item.coverColor}};">
              <view class="feat-card__grad">
                <text class="feat-card__char">{{item.characterName}}</text>
                <text class="feat-card__sub">{{item.title}}</text>
                <view class="feat-card__row">
                  <text class="feat-card__auth">{{item.author}}</text>
                  <text class="feat-card__like">{{item.likeCount}} 喜欢</text>
                </view>
              </view>
            </view>
          </view>
        </block>
      </view>
    </view>

    <!-- 4. 动态转化瀑布流 -->
    <view class="home-feed-head">
      <text class="home-feed-head__title">发现</text>
      <text class="home-feed-head__sub">作品 · 转化挂载</text>
    </view>
    <view class="home-masonry">
      <view class="home-masonry__col">
        <block wx:for="{{feedLeft}}" wx:key="id">
          <view class="feed-card">
            <view class="feed-card__media">
              <image
                wx:if="{{item.coverUrl}}"
                class="feed-card__img"
                src="{{item.coverUrl}}"
                mode="aspectFill"
              />
              <view
                wx:else
                class="feed-card__img feed-card__img--ph"
                style="background-color: {{item.coverColor}};"
              />
            </view>
            <view class="feed-card__body">
              <text class="feed-card__title">{{item.title}}</text>
              <view
                class="feed-conv feed-conv--{{item.conversion.type}}"
                bindtap="onConversionTap"
                data-id="{{item.id}}"
                data-ctype="{{item.conversion.type}}"
                data-trade-item-id="{{item.convTradeItemId}}"
                data-artist-id="{{item.convArtistId}}"
              >
                <text class="feed-conv__text">{{item.conversion.label}}</text>
              </view>
              <view class="feed-card__foot">
                <view
                  class="feed-card__ava"
                  style="background-color: {{item.author.avatarUrl ? 'transparent' : '#e8e8e8'}};"
                >
                  <image
                    wx:if="{{item.author.avatarUrl}}"
                    class="feed-card__ava-img"
                    src="{{item.author.avatarUrl}}"
                    mode="aspectFill"
                  />
                  <text wx:else class="feed-card__ava-t">{{item.authorInitial}}</text>
                </view>
                <text class="feed-card__nick">{{item.author.nickname}}</text>
                <view wx:if="{{item.author.verified}}" class="feed-card__v">V</view>
              </view>
            </view>
          </view>
        </block>
      </view>
      <view class="home-masonry__col">
        <block wx:for="{{feedRight}}" wx:key="id">
          <view class="feed-card">
            <view class="feed-card__media">
              <image
                wx:if="{{item.coverUrl}}"
                class="feed-card__img"
                src="{{item.coverUrl}}"
                mode="aspectFill"
              />
              <view
                wx:else
                class="feed-card__img feed-card__img--ph"
                style="background-color: {{item.coverColor}};"
              />
            </view>
            <view class="feed-card__body">
              <text class="feed-card__title">{{item.title}}</text>
              <view
                class="feed-conv feed-conv--{{item.conversion.type}}"
                bindtap="onConversionTap"
                data-id="{{item.id}}"
                data-ctype="{{item.conversion.type}}"
                data-trade-item-id="{{item.convTradeItemId}}"
                data-artist-id="{{item.convArtistId}}"
              >
                <text class="feed-conv__text">{{item.conversion.label}}</text>
              </view>
              <view class="feed-card__foot">
                <view
                  class="feed-card__ava"
                  style="background-color: {{item.author.avatarUrl ? 'transparent' : '#e8e8e8'}};"
                >
                  <image
                    wx:if="{{item.author.avatarUrl}}"
                    class="feed-card__ava-img"
                    src="{{item.author.avatarUrl}}"
                    mode="aspectFill"
                  />
                  <text wx:else class="feed-card__ava-t">{{item.authorInitial}}</text>
                </view>
                <text class="feed-card__nick">{{item.author.nickname}}</text>
                <view wx:if="{{item.author.verified}}" class="feed-card__v">V</view>
              </view>
            </view>
          </view>
        </block>
      </view>
    </view>

    <view class="home-foot" wx:if="{{showDevProbe && healthLabel}}">
      <text class="home-foot__t">{{healthLabel}}</text>
      <text wx:if="{{healthTrace}}" class="home-foot__trace" selectable="true">{{healthTrace}}</text>
    </view>
    <view class="home-foot-spacer"></view>
  </scroll-view>
</view>
