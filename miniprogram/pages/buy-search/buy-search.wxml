<view class="bs-page">
  <view class="bs-search-row">
    <input
      class="bs-search-input"
      type="text"
      confirm-type="search"
      placeholder="搜商品，如：Cos服"
      placeholder-class="bs-search-input__ph"
      value="{{keyword}}"
      bindinput="onKeywordInput"
      bindconfirm="onKeywordConfirm"
    />
    <view class="bs-search-btn" bindtap="onSearchConfirmTap">搜索</view>
  </view>

  <scroll-view class="bs-cat-scroll" scroll-x enable-flex="{{true}}" show-scrollbar="{{false}}">
    <view class="bs-cat-inner">
      <view
        wx:for="{{chipsView}}"
        wx:key="id"
        class="bs-pill {{item.on ? 'bs-pill--on' : ''}}"
        bindtap="onChipTap"
        data-id="{{item.id}}"
      >
        {{item.label}}
      </view>
    </view>
  </scroll-view>

  <view class="bs-sort-bar">
    <scroll-view
      class="bs-sort-scroll"
      scroll-x="{{true}}"
      show-scrollbar="{{false}}"
      enable-flex="{{true}}"
    >
      <view class="bs-sort-scroll__inner">
        <text
          class="bs-sort {{sortKey === 'comp' ? 'bs-sort--on' : ''}}"
          bindtap="onSortTap"
          data-k="comp"
        >
          综合
        </text>
        <text
          class="bs-sort {{sortKey === 'price' ? 'bs-sort--on' : ''}}"
          bindtap="onSortTap"
          data-k="price"
        >
          {{sortKey === 'price' ? (sortDirAsc ? '价格↑' : '价格↓') : '价格'}}
        </text>
        <text
          class="bs-sort {{sortKey === 'drop' ? 'bs-sort--on' : ''}}"
          bindtap="onSortTap"
          data-k="drop"
        >
          降价
        </text>
        <text
          class="bs-sort {{sortKey === 'new' ? 'bs-sort--on' : ''}}"
          bindtap="onSortTap"
          data-k="new"
        >
          新发
        </text>
        <text
          class="bs-sort {{regionChips.length ? 'bs-sort--on' : 'bs-sort--muted'}}"
          bindtap="onSortTap"
          data-k="region"
        >
          区域
        </text>
      </view>
    </scroll-view>
    <view class="bs-filter-trigger" bindtap="openPriceModal">
      <view class="bs-filter-ico" aria-hidden="true">
        <view class="bs-filter-ico__line" />
        <view class="bs-filter-ico__line bs-filter-ico__line--mid" />
        <view class="bs-filter-ico__line" />
      </view>
      <text class="bs-filter-trigger__txt">筛选</text>
    </view>
  </view>

  <view wx:if="{{filterSummaryVisible}}" class="bs-filter-result">
    <text class="bs-filter-result__hint">已选条件</text>
    <scroll-view
      class="bs-filter-result__scroll"
      scroll-x="{{true}}"
      show-scrollbar="{{false}}"
      enable-flex="{{true}}"
    >
      <view class="bs-filter-result__inner">
        <view
          wx:for="{{filterSummaryChips}}"
          wx:key="id"
          class="bs-filter-tag"
          bindtap="onRemoveFilterChip"
          data-id="{{item.id}}"
        >
          <text class="bs-filter-tag__txt">{{item.label}}</text>
          <text class="bs-filter-tag__x">×</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <block wx:if="{{loading}}">
    <view class="bs-skel-grid">
      <view class="bs-skel-col">
        <view class="bs-skel-card">
          <view class="bs-skel-card__ph bs-skel-card__ph--tall" />
          <view class="bs-skel-card__bar" />
          <view class="bs-skel-card__bar bs-skel-card__bar--short" />
        </view>
        <view class="bs-skel-card">
          <view class="bs-skel-card__ph" />
          <view class="bs-skel-card__bar" />
        </view>
      </view>
      <view class="bs-skel-col">
        <view class="bs-skel-card">
          <view class="bs-skel-card__ph" />
          <view class="bs-skel-card__bar" />
        </view>
        <view class="bs-skel-card">
          <view class="bs-skel-card__ph bs-skel-card__ph--tall" />
          <view class="bs-skel-card__bar" />
        </view>
      </view>
    </view>
  </block>

  <block wx:elif="{{error}}">
    <view class="bs-empty-wrap">
      <text class="bs-empty-title">{{error.userTitle}}</text>
      <text class="bs-empty-sub cos-meta">请检查网络后重试</text>
      <button class="bs-retry-btn" bindtap="refresh">重试</button>
    </view>
  </block>

  <block wx:elif="{{empty}}">
    <view class="bs-empty-wrap">
      <text class="bs-empty-title">暂无匹配商品</text>
      <text class="bs-empty-sub cos-meta">试试其它分类或清空筛选</text>
    </view>
  </block>

  <block wx:else>
    <view class="bs-grid">
      <view class="bs-grid__col">
        <block wx:for="{{displayLeft}}" wx:key="item_id">
          <view
            class="bs-card {{item.cardLarge ? 'bs-card--large' : 'bs-card--small'}}"
            bindtap="onCardTap"
            data-item-id="{{item.item_id}}"
          >
            <view wx:if="{{item.pinned}}" class="bs-card__pin">置顶</view>
            <view class="bs-card__media">
              <view wx:if="{{item.cardLarge}}" class="bs-card__aspect">
                <view class="bs-card__aspect-inner">
                  <view class="bs-card__ph bs-card__ph--grad" />
                </view>
              </view>
              <view wx:else class="bs-card__ph bs-card__ph--short bs-card__ph--grad" />
            </view>
            <view class="bs-card__body">
              <text class="bs-card__title {{item.cardLarge ? '' : 'bs-card__title--one'}}">{{item.title}}</text>
              <text class="bs-card__price">¥{{item.priceYuan}}</text>
              <text class="bs-card__region">{{item.region}}</text>
              <view wx:if="{{item.cardLarge}}" class="bs-card__tag">{{item.sellerTag}}</view>
            </view>
          </view>
        </block>
      </view>
      <view class="bs-grid__col">
        <block wx:for="{{displayRight}}" wx:key="item_id">
          <view
            class="bs-card {{item.cardLarge ? 'bs-card--large' : 'bs-card--small'}}"
            bindtap="onCardTap"
            data-item-id="{{item.item_id}}"
          >
            <view wx:if="{{item.pinned}}" class="bs-card__pin">置顶</view>
            <view class="bs-card__media">
              <view wx:if="{{item.cardLarge}}" class="bs-card__aspect">
                <view class="bs-card__aspect-inner">
                  <view class="bs-card__ph bs-card__ph--grad" />
                </view>
              </view>
              <view wx:else class="bs-card__ph bs-card__ph--short bs-card__ph--grad" />
            </view>
            <view class="bs-card__body">
              <text class="bs-card__title {{item.cardLarge ? '' : 'bs-card__title--one'}}">{{item.title}}</text>
              <text class="bs-card__price">¥{{item.priceYuan}}</text>
              <text class="bs-card__region">{{item.region}}</text>
              <view wx:if="{{item.cardLarge}}" class="bs-card__tag">{{item.sellerTag}}</view>
            </view>
          </view>
        </block>
      </view>
    </view>
    <view class="bs-load-more cos-meta" wx:if="{{nextCursor}}">
      <text wx:if="{{loadingMore}}">加载中…</text>
      <text wx:else>上拉加载更多</text>
    </view>
  </block>

  <view class="bs-tab-spacer" />

  <view
    wx:if="{{showCompModal}}"
    class="bs-modal-mask {{compModalDismissAnim ? 'bs-modal-mask--leave' : ''}}"
    catchtap="closeCompModal"
  >
    <view class="bs-modal bs-modal--center bs-modal--comp" catchtap="noop">
      <view class="bs-modal__head bs-modal__head--purple">
        <text class="bs-modal__purple-title">综合排序</text>
        <text class="bs-modal__check" bindtap="confirmCompModal">√</text>
      </view>
      <view
        class="bs-comp-opt {{compModalDraft === 'default' ? 'bs-comp-opt--on' : ''}}"
        bindtap="onCompDraftTap"
        data-v="default"
      >
        综合排序
      </view>
      <view
        class="bs-comp-opt {{compModalDraft === 'active' ? 'bs-comp-opt--on' : ''}}"
        bindtap="onCompDraftTap"
        data-v="active"
      >
        最近活跃
      </view>
      <view
        class="bs-comp-opt {{compModalDraft === 'near' ? 'bs-comp-opt--on' : ''}}"
        bindtap="onCompDraftTap"
        data-v="near"
      >
        离我最近
      </view>
      <view
        class="bs-comp-opt {{compModalDraft === 'credit' ? 'bs-comp-opt--on' : ''}}"
        bindtap="onCompDraftTap"
        data-v="credit"
      >
        信用排序
      </view>
    </view>
  </view>

  <view
    wx:if="{{showPriceModal}}"
    class="bs-modal-mask {{priceModalDismissAnim ? 'bs-modal-mask--leave' : ''}}"
    catchtap="closePriceModal"
  >
    <view class="bs-modal bs-modal--center bs-modal--price" catchtap="noop">
      <text class="bs-modal__purple-title bs-modal__purple-title--solo">价格区间</text>
      <view class="bs-modal__chips">
        <view
          class="bs-chip {{priceDraftMode === 'preset' && filterDraftSeg === 'any' ? 'bs-chip--on' : ''}}"
          bindtap="onModalPriceTap"
          data-seg="any"
        >
          不限
        </view>
        <view
          class="bs-chip {{priceDraftMode === 'preset' && filterDraftSeg === '0-50' ? 'bs-chip--on' : ''}}"
          bindtap="onModalPriceTap"
          data-seg="0-50"
        >
          50以下
        </view>
        <view
          class="bs-chip {{priceDraftMode === 'preset' && filterDraftSeg === '50-100' ? 'bs-chip--on' : ''}}"
          bindtap="onModalPriceTap"
          data-seg="50-100"
        >
          50-100
        </view>
        <view
          class="bs-chip {{priceDraftMode === 'preset' && filterDraftSeg === '100-300' ? 'bs-chip--on' : ''}}"
          bindtap="onModalPriceTap"
          data-seg="100-300"
        >
          100-300
        </view>
        <view
          class="bs-chip {{priceDraftMode === 'preset' && filterDraftSeg === '300-500' ? 'bs-chip--on' : ''}}"
          bindtap="onModalPriceTap"
          data-seg="300-500"
        >
          300-500
        </view>
        <view
          class="bs-chip {{priceDraftMode === 'preset' && filterDraftSeg === '500+' ? 'bs-chip--on' : ''}}"
          bindtap="onModalPriceTap"
          data-seg="500+"
        >
          500以上
        </view>
      </view>
      <view class="bs-modal__row {{priceDraftMode === 'preset' ? 'bs-modal__row--price-muted' : ''}}" catchtap="onPriceCustomRowTap">
        <input
          class="bs-modal__input"
          type="digit"
          placeholder="最低价"
          value="{{filterDraftMin}}"
          disabled="{{priceDraftMode === 'preset'}}"
          bindinput="onDraftMinInput"
        />
        <text class="bs-modal__dash">~</text>
        <input
          class="bs-modal__input"
          type="digit"
          placeholder="最高价"
          value="{{filterDraftMax}}"
          disabled="{{priceDraftMode === 'preset'}}"
          bindinput="onDraftMaxInput"
        />
      </view>
      <text class="bs-modal__sec bs-modal__sec--purple">排序方向</text>
      <view class="bs-modal__chips">
        <view
          class="bs-chip {{priceModalDirAsc ? 'bs-chip--on' : ''}}"
          bindtap="onPriceDirTap"
          data-asc="1"
        >
          从低到高
        </view>
        <view
          class="bs-chip {{!priceModalDirAsc ? 'bs-chip--on' : ''}}"
          bindtap="onPriceDirTap"
          data-asc="0"
        >
          从高到低
        </view>
      </view>
      <view class="bs-modal__footer">
        <button class="bs-modal__apply bs-modal__apply--end" bindtap="applyPriceModal">应用</button>
      </view>
    </view>
  </view>

  <view wx:if="{{showRegionModal}}" class="bs-modal-mask" catchtap="closeRegionModal">
    <view class="bs-modal bs-modal--center bs-modal--region" catchtap="noop">
      <text class="bs-modal__purple-title bs-modal__purple-title--solo">选择区域</text>
      <picker-view
        class="bs-region-picker"
        indicator-style="height: 72rpx;"
        style="width: 100%; height: 360rpx"
        value="{{regionPickerValue}}"
        bindchange="onRegionPickerChange"
      >
        <picker-view-column>
          <view
            wx:for="{{regionPickerProvinces}}"
            wx:key="*this"
            class="bs-pv-item"
          >
            {{item}}
          </view>
        </picker-view-column>
        <picker-view-column>
          <view
            wx:for="{{regionPickerCities}}"
            wx:key="*this"
            class="bs-pv-item"
          >
            {{item}}
          </view>
        </picker-view-column>
        <picker-view-column>
          <view
            wx:for="{{regionPickerDistricts}}"
            wx:key="*this"
            class="bs-pv-item"
          >
            {{item}}
          </view>
        </picker-view-column>
      </picker-view>
      <view class="bs-modal__footer">
        <button class="bs-modal__apply bs-modal__apply--end" bindtap="confirmRegionModal">
          确定
        </button>
      </view>
    </view>
  </view>
</view>
