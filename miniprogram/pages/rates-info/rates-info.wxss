.rates-page {
  height: 100vh;
  box-sizing: border-box;
}

.rates-scroll {
  height: 100%;
  box-sizing: border-box;
}

.rates-inner {
  padding: 24rpx 24rpx 80rpx;
  box-sizing: border-box;
}

.rates-nav {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx 20rpx;
  margin-bottom: 24rpx;
  padding: 4rpx 0;
}

.rates-nav-item {
  font-size: 26rpx;
  color: #7c3aed;
  padding: 10rpx 20rpx;
  border-radius: var(--radius-pill, 999rpx);
  border: 2rpx solid rgba(153, 102, 255, 0.45);
  background-color: #ffffff;
}

.scroll-anchor {
  scroll-margin-top: 24rpx;
}

.section {
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.para {
  display: block;
  line-height: 1.55;
}
