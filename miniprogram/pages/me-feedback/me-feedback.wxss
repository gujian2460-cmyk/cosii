.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 80rpx;
  box-sizing: border-box;
}

.draft-hint {
  display: block;
  margin: 0 8rpx 16rpx;
  color: var(--color-text-muted, #6b7280);
}

.section {
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.field {
  width: 100%;
  padding: 20rpx 24rpx;
  border-radius: var(--radius-md, 16rpx);
  border: 2rpx solid var(--color-border);
  font-size: 28rpx;
  box-sizing: border-box;
}

.textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx 24rpx;
  border-radius: var(--radius-md, 16rpx);
  border: 2rpx solid var(--color-border);
  font-size: 28rpx;
  box-sizing: border-box;
}

.submit {
  width: calc(100% - 48rpx);
  margin: 16rpx 24rpx 0;
}

.foot {
  display: block;
  margin: 24rpx;
  text-align: center;
}
