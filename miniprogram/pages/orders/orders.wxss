.page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding-top: 120rpx;
}

.empty-title {
  font-weight: 600;
  font-size: 32rpx;
  margin-bottom: 16rpx;
}

.empty-desc {
  max-width: 560rpx;
  margin-bottom: 48rpx;
  line-height: 1.5;
}

.empty-btn {
  min-width: 320rpx;
}

.status-scroll {
  width: 100%;
  margin-bottom: 24rpx;
  white-space: nowrap;
}

.status-row {
  display: inline-flex;
  flex-direction: row;
  gap: 12rpx;
  padding-bottom: 8rpx;
}

.status-chip {
  display: inline-block;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--color-border);
  background-color: var(--color-surface);
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.status-chip--on {
  border-color: var(--color-secondary);
  color: var(--color-secondary);
}

.segmented {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.seg-item {
  padding: 12rpx 28rpx;
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
  background-color: var(--color-surface);
}

.seg-item--on {
  border-color: var(--color-primary);
  color: var(--color-primary);
}

.order-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.order-row-main {
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
}

.order-title {
  display: block;
  font-weight: 500;
}

.order-sub {
  display: block;
  margin-top: 8rpx;
}

.order-amt {
  flex-shrink: 0;
}

.load-more {
  text-align: center;
  padding: 24rpx 0 48rpx;
  opacity: 0.75;
}
