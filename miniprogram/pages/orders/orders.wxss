.page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding-top: 120rpx;
}

.empty-title {
  font-weight: 600;
  font-size: 32rpx;
  margin-bottom: 16rpx;
}

.empty-desc {
  max-width: 560rpx;
  margin-bottom: 48rpx;
  line-height: 1.5;
}

.empty-btn {
  min-width: 320rpx;
}
