<view class="page">
  <block wx:if="{{loading}}">
    <view class="cos-skeleton">
      <view class="cos-skeleton-line"></view>
      <view class="cos-skeleton-line"></view>
      <view class="cos-skeleton-line cos-skeleton-line--short"></view>
    </view>
  </block>
  <block wx:elif="{{error}}">
    <view class="cos-page-state">
      <text class="cos-body">{{error.userTitle}}</text>
      <text wx:if="{{error.traceId}}" class="cos-code cos-meta" selectable="true">{{error.traceId}}</text>
      <button class="cos-btn-primary cos-page-state__retry" bindtap="refresh">重试</button>
    </view>
  </block>
  <block wx:else>
    <view class="segmented cos-meta">
      <view
        class="seg-item {{activeFilter === 'all' ? 'seg-item--on' : ''}}"
        bindtap="onFilterTap"
        data-filter="all"
      >全部</view>
      <view
        class="seg-item {{activeFilter === 'trade' ? 'seg-item--on' : ''}}"
        bindtap="onFilterTap"
        data-filter="trade"
      >闲置</view>
      <view
        class="seg-item {{activeFilter === 'service' ? 'seg-item--on' : ''}}"
        bindtap="onFilterTap"
        data-filter="service"
      >约妆</view>
    </view>
    <scroll-view class="status-scroll" scroll-x="true" enable-flex="true">
      <view class="status-row">
        <view
          class="status-chip {{activeStatus === '' ? 'status-chip--on' : ''}}"
          bindtap="onStatusTap"
          data-status="__all__"
        >状态不限</view>
        <view
          class="status-chip {{activeStatus === 'PENDING_PAYMENT' ? 'status-chip--on' : ''}}"
          bindtap="onStatusTap"
          data-status="PENDING_PAYMENT"
        >待付款</view>
        <view
          class="status-chip {{activeStatus === 'PAID_ESCROW' ? 'status-chip--on' : ''}}"
          bindtap="onStatusTap"
          data-status="PAID_ESCROW"
        >担保中</view>
        <view
          class="status-chip {{activeStatus === 'DEPOSIT_PAID' ? 'status-chip--on' : ''}}"
          bindtap="onStatusTap"
          data-status="DEPOSIT_PAID"
        >已付定金</view>
        <view
          class="status-chip {{activeStatus === 'COMPLETED' ? 'status-chip--on' : ''}}"
          bindtap="onStatusTap"
          data-status="COMPLETED"
        >已完成</view>
        <view
          class="status-chip {{activeStatus === 'DISPUTED' ? 'status-chip--on' : ''}}"
          bindtap="onStatusTap"
          data-status="DISPUTED"
        >争议中</view>
      </view>
    </scroll-view>
    <block wx:if="{{empty}}">
      <view class="empty">
        <text class="empty-title cos-body">暂无订单</text>
        <text class="cos-meta empty-desc">订单详情为状态真源；可切换类型与状态筛选。</text>
        <button class="cos-btn-primary empty-btn" bindtap="goHome">去首页逛逛</button>
      </view>
    </block>
    <block wx:else>
      <view
        class="order-row cos-card"
        wx:for="{{orders}}"
        wx:key="unified_order_id"
        bindtap="onOrderTap"
        data-unified-id="{{item.unified_order_id}}"
        data-order-type="{{item.order_type}}"
        data-domain-id="{{item.domain_order_id}}"
      >
        <view class="order-row-main">
          <text class="cos-body order-title">{{item.title}}</text>
          <text class="cos-meta order-sub">{{item.order_type}} · {{item.status}}</text>
        </view>
        <text class="cos-body cos-tabular order-amt">¥{{item.amountYuan}}</text>
      </view>
      <view class="load-more cos-meta" wx:if="{{nextCursor}}">
        <text wx:if="{{loadingMore}}">加载中…</text>
        <text wx:else>上拉加载更多</text>
      </view>
    </block>
  </block>
</view>
