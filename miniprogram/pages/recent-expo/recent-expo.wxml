<view class="rex-page">
  <input
    class="rex-search"
    type="text"
    placeholder="搜索漫展名称/城市"
    placeholder-class="rex-search__ph"
    value="{{keyword}}"
    bindinput="onSearchInput"
    confirm-type="search"
  />
  <view class="rex-list">
    <view
      wx:for="{{displayList}}"
      wx:key="id"
      class="rex-card"
      bindtap="onExpoTap"
      data-id="{{item.id}}"
    >
      <view class="rex-card__poster" />
      <view class="rex-card__body">
        <view class="rex-card__line rex-card__line--1" />
        <view class="rex-card__line rex-card__line--2" />
      </view>
    </view>
  </view>
  <view wx:if="{{loadingMore}}" class="rex-foot rex-foot--muted">加载中…</view>
  <view wx:elif="{{!hasMore && displayList.length > 0}}" class="rex-foot rex-foot--muted">没有更多了</view>
  <view wx:if="{{!displayList.length && !loadingMore}}" class="rex-empty cos-meta">暂无匹配的漫展</view>
</view>
