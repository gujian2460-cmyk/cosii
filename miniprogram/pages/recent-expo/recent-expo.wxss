.rex-page {
  min-height: 100vh;
  background-color: #ffffff;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.rex-search {
  width: 100%;
  height: 72rpx;
  padding: 0 28rpx;
  margin-bottom: 24rpx;
  background-color: #eceef2;
  border-radius: var(--radius-pill);
  font-size: 26rpx;
  color: #111111;
  box-sizing: border-box;
}

.rex-search__ph {
  color: #999999;
}

.rex-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.rex-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-soft);
}

.rex-card__poster {
  width: 100%;
  height: 280rpx;
  background: linear-gradient(145deg, #ede9fe 0%, #ddd6fe 45%, #e9d5ff 100%);
}

.rex-card__body {
  padding: 24rpx 20rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rex-card__line {
  height: 28rpx;
  border-radius: 8rpx;
  background: linear-gradient(90deg, #fce7f3 0%, #fbcfe8 40%, #fce7f3 100%);
}

.rex-card__line--1 {
  width: 100%;
}

.rex-card__line--2 {
  width: 62%;
}

.rex-foot {
  text-align: center;
  padding: 32rpx 0 16rpx;
  font-size: 24rpx;
}

.rex-foot--muted {
  color: var(--color-text-muted);
}

.rex-empty {
  text-align: center;
  padding: 80rpx 32rpx 0;
}
