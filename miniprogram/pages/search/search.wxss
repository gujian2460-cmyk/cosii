.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 120rpx;
  box-sizing: border-box;
}

.state-hint {
  display: block;
  margin-top: 16rpx;
}

.state-retry {
  width: 100%;
  margin-top: 28rpx;
}

.search-head {
  margin-bottom: 32rpx;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.search-input-wrap {
  flex: 1;
  margin: 0;
  display: flex;
  align-items: center;
}

.search-input-wrap .search-input {
  flex: 1;
  min-width: 0;
}

.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: var(--color-text);
}

.search-ph {
  color: #9ca3af;
}

.search-clear {
  padding: 0 8rpx;
  color: var(--color-text-muted);
  font-size: 28rpx;
}

.search-action {
  flex-shrink: 0;
  color: var(--color-primary-dark);
  font-weight: 600;
  padding: 16rpx 8rpx;
}

.section {
  margin-bottom: 40rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-weight: 600;
}

.section-clear {
  padding: 8rpx 0;
}

.section-empty {
  display: block;
  padding: 8rpx 0;
}

.tag-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.result-hint {
  display: block;
  margin-bottom: 24rpx;
}

.waterfall {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.waterfall-col {
  flex: 1;
  min-width: 0;
}

.feed-card {
  margin-bottom: 16rpx;
  padding: 20rpx;
}

.feed-title {
  display: block;
  font-weight: 600;
  font-size: 26rpx;
  line-height: 1.35;
}

.tag-mt {
  margin-top: 12rpx;
}

.feed-price {
  display: block;
  margin-top: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-secondary);
}

.feed-buy {
  margin-top: 16rpx;
  width: 100% !important;
  font-size: 24rpx !important;
  padding: 12rpx 16rpx !important;
}
