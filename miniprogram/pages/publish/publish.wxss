.pub-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  background-color: #f5f5f7;
}

.pub-nav {
  flex-shrink: 0;
  background-color: #ffffff;
  border-bottom: 1rpx solid var(--color-border);
}

.pub-nav__row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 8rpx;
  box-sizing: border-box;
}

.pub-nav__side {
  width: 88rpx;
  flex-shrink: 0;
}

.pub-nav__back {
  font-size: 48rpx;
  font-weight: 300;
  color: var(--color-text);
  line-height: 1;
  padding: 8rpx 16rpx;
}

.pub-nav__title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
}

.pub-tabs {
  flex-shrink: 0;
  display: flex;
  flex-direction: row;
  width: 100%;
  background-color: #ffffff;
  border-bottom: 1rpx solid var(--color-border);
}

.pub-tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0 20rpx;
  font-size: 30rpx;
  color: #6b7280;
  border-bottom: 4rpx solid transparent;
  box-sizing: border-box;
}

.pub-tab--on {
  color: var(--color-primary);
  font-weight: 700;
  border-bottom-color: var(--color-primary);
}

.pub-scroll {
  flex: 1;
  min-height: 0;
  width: 100%;
  box-sizing: border-box;
  padding: 16rpx 16rpx 0;
}

.pub-card {
  background-color: #ffffff;
  border-radius: var(--radius-lg);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-soft);
  box-sizing: border-box;
}

.pub-card--row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.pub-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 16rpx;
}

.pub-card--row .pub-label {
  flex-shrink: 0;
  margin-bottom: 0;
}

.pub-input {
  width: 100%;
  min-height: 72rpx;
  font-size: 28rpx;
  color: var(--color-text);
  box-sizing: border-box;
}

.pub-input--right {
  text-align: right;
  flex: 1;
  min-width: 0;
}

.pub-textarea {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  color: var(--color-text);
  box-sizing: border-box;
}

.pub-picker-val {
  font-size: 28rpx;
  color: var(--color-text);
  text-align: right;
  flex: 1;
  min-width: 0;
}

.pub-picker-val--ph {
  color: var(--color-text-muted);
}

.pub-uploads {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}

.pub-thumb-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
}

.pub-thumb {
  width: 100%;
  height: 100%;
  background-color: #f3f4f6;
}

.pub-thumb-del {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 44rpx;
  height: 44rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: 32rpx;
  color: #ffffff;
  background-color: rgba(0, 0, 0, 0.45);
  border-radius: 50%;
}

.pub-upload-add {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-md);
  border: 2rpx dashed #c4b5fd;
  background-color: #faf5ff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.pub-upload-plus {
  font-size: 56rpx;
  font-weight: 300;
  color: var(--color-primary);
  line-height: 1;
}

.pub-upload-hint {
  font-size: 20rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
}

.pub-commit {
  background-color: #ffffff;
  border-radius: var(--radius-lg);
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-soft);
  box-sizing: border-box;
}

.pub-commit__row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 16rpx;
}

.pub-commit__cb {
  margin-top: 4rpx;
  transform: scale(0.92);
}

.pub-commit__txt {
  flex: 1;
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
}

.pub-scroll-pad {
  height: calc(280rpx + env(safe-area-inset-bottom));
}

.pub-bottom {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 520;
  bottom: calc(100rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 24rpx;
  background-color: #ffffff;
  border-top: 1rpx solid var(--color-border);
  box-shadow: 0 -8rpx 24rpx rgba(15, 23, 42, 0.06);
  box-sizing: border-box;
}

.pub-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--radius-md);
  padding: 0;
  margin: 0;
  border: none;
}

.pub-btn::after {
  border: none;
}

.pub-btn--ghost {
  background-color: #f3f4f6 !important;
  color: #374151 !important;
}

.pub-btn--primary {
  background: linear-gradient(135deg, #9966ff, #7c3aed) !important;
  color: #ffffff !important;
}

.pub-btn--primary[disabled] {
  opacity: 0.45;
}

.pub-btn--block {
  flex: none;
  width: 100%;
}

.pub-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.45);
  z-index: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
}

.pub-region-sheet {
  width: 100%;
  max-width: 620rpx;
  background-color: #ffffff;
  border-radius: var(--radius-lg);
  padding: 28rpx;
  box-shadow: 0 20rpx 60rpx rgba(17, 24, 39, 0.16);
  box-sizing: border-box;
}

.pub-region-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 16rpx;
  text-align: center;
}

.pub-region-pv {
  width: 100%;
  margin-bottom: 16rpx;
}

.pub-pv-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  color: #374151;
}

.pub-region-actions {
  margin-top: 8rpx;
}
