<view class="page">
  <block wx:if="{{loading}}">
    <view class="cos-skeleton">
      <view class="cos-skeleton-line"></view>
    </view>
  </block>
  <block wx:elif="{{error}}">
    <view class="cos-page-state">
      <text class="cos-body">{{error.userTitle}}</text>
    </view>
  </block>
  <block wx:else>
    <text class="lead cos-body">选择发布类型</text>
    <view class="cos-card item" bindtap="onPublishTrade">
      <text class="title cos-body">发布商品</text>
      <text class="cos-meta">闲置 / 装备上架</text>
    </view>
    <view class="cos-card item" bindtap="onPublishPost">
      <text class="title cos-body">发布作品</text>
      <text class="cos-meta">图文内容 + 转化卡</text>
    </view>
  </block>
</view>
