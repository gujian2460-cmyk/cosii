<view class="me-page">
  <block wx:if="{{loading}}">
    <view class="cos-skeleton me-sk">
      <view class="cos-skeleton-line"></view>
    </view>
  </block>
  <block wx:elif="{{error}}">
    <view class="cos-page-state">
      <text class="cos-body">{{error.userTitle}}</text>
    </view>
  </block>
  <block wx:else>
    <view class="me-hero">
      <block wx:if="{{isLoggedIn && profile}}">
        <view class="me-hero__avatar-wrap">
          <view class="me-hero__avatar">{{avatarLetter}}</view>
        </view>
        <text class="me-hero__name">{{profile.nickname}}</text>
        <text class="me-hero__meta">ID {{profile.user_id}} · {{profile.role}}</text>
        <button class="me-hero__btn" size="mini" bindtap="onLoginTap">切换账号</button>
      </block>
      <block wx:else>
        <text class="me-hero__welcome">Cosii</text>
        <text class="me-hero__sub">担保交易 · 约妆档期 · 内容转化</text>
        <button class="me-hero__btn me-hero__btn--solid" bindtap="onLoginTap">微信登录 / 模拟登录</button>
      </block>
    </view>

    <view class="me-sheet">
      <text class="me-section-label">交易</text>
      <view class="me-grid">
        <view class="me-grid__cell" bindtap="onOrders">
          <text class="me-grid__t">卖出</text>
        </view>
        <view class="me-grid__cell" bindtap="onOrders">
          <text class="me-grid__t">买入</text>
        </view>
        <view class="me-grid__cell" bindtap="onPlaceholder">
          <text class="me-grid__t">租出</text>
        </view>
        <view class="me-grid__cell" bindtap="onPlaceholder">
          <text class="me-grid__t">租入</text>
        </view>
      </view>

      <text class="me-section-label">内容</text>
      <view class="me-grid">
        <view class="me-grid__cell" bindtap="onGoPublish">
          <text class="me-grid__t">发布</text>
        </view>
        <view class="me-grid__cell" bindtap="onPlaceholder">
          <text class="me-grid__t">作品</text>
        </view>
        <view class="me-grid__cell" bindtap="onPlaceholder">
          <text class="me-grid__t">收藏</text>
        </view>
        <view class="me-grid__cell" bindtap="onPlaceholder">
          <text class="me-grid__t">草稿</text>
        </view>
      </view>

      <view class="me-grid me-grid--one">
        <view class="me-grid__cell me-grid__cell--wide" bindtap="onPlaceholder">
          <text class="me-grid__t">地址管理</text>
        </view>
      </view>

      <view class="me-list cos-card">
        <view class="cell cos-body" bindtap="onOrders">
          <text>我的订单</text>
          <text class="cos-meta">›</text>
        </view>
        <view class="cell cos-body" bindtap="onInbox">
          <text>消息通知</text>
          <text class="cos-meta">›</text>
        </view>
      </view>

      <view class="me-list cos-card list--mt">
        <view class="cell cos-body" bindtap="onRates">
          <text>费率与结算说明</text>
          <text class="cos-meta">›</text>
        </view>
        <view class="cell cos-body" bindtap="onSettings">
          <text>设置</text>
          <text class="cos-meta">›</text>
        </view>
        <view class="cell cos-body" bindtap="onPlaceholder">
          <text>问题反馈</text>
          <text class="cos-meta">›</text>
        </view>
      </view>
    </view>
  </block>
</view>
