<view class="me-page">
  <block wx:if="{{loading}}">
    <view class="cos-skeleton me-sk">
      <view class="cos-skeleton-line"></view>
    </view>
  </block>
  <block wx:elif="{{error}}">
    <view class="cos-page-state">
      <text class="cos-body">{{error.userTitle}}</text>
    </view>
  </block>
  <block wx:else>
    <view class="me-hero">
      <block wx:if="{{isLoggedIn && profile}}">
        <view class="me-hero__avatar-wrap">
          <view class="me-hero__avatar">{{avatarLetter}}</view>
        </view>
        <text class="me-hero__name">{{profile.nickname}}</text>
        <text class="me-hero__meta">ID {{profile.user_id}} · {{profile.role}}</text>
        <button class="me-hero__btn" size="mini" bindtap="onLoginTap">切换账号</button>
      </block>
      <block wx:else>
        <text class="me-hero__welcome">Cosii</text>
        <text class="me-hero__sub">担保交易 · 约妆档期 · 内容转化</text>
        <button class="me-hero__btn me-hero__btn--solid" bindtap="onLoginTap">微信登录 / 模拟登录</button>
      </block>
    </view>

    <view class="me-sheet">
      <view class="me-quick">
        <view
          class="me-quick__card"
          wx:for="{{quickEntries}}"
          wx:key="id"
          bindtap="onEntryTap"
          data-id="{{item.id}}"
        >
          <text class="me-quick__title">{{item.label}}</text>
          <text class="me-quick__sub">{{item.sub}}</text>
        </view>
      </view>

      <text class="me-section-label">常用功能</text>
      <view class="me-grid">
        <view
          class="me-grid__cell"
          wx:for="{{featureEntries}}"
          wx:key="id"
          bindtap="onEntryTap"
          data-id="{{item.id}}"
        >
          <text class="me-grid__t">{{item.label}}</text>
        </view>
      </view>

      <text class="me-section-label">账号与服务</text>
      <view class="me-list cos-card list--mt">
        <view
          class="cell cos-body"
          wx:for="{{serviceEntries}}"
          wx:key="id"
          bindtap="onEntryTap"
          data-id="{{item.id}}"
        >
          <text>{{item.label}}</text>
          <text class="cos-meta">›</text>
        </view>
      </view>
    </view>
  </block>
</view>
