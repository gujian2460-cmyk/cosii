# Cosii API — 生产环境变量示例
# 用法：复制本文件到服务器安全位置（勿提交含真实值的文件到 Git），
# 在 systemd 里用 EnvironmentFile= 加载，或 `export` 后启动 node。
#
# 变量说明全文：docs/tutorials/生产环境变量与真机联调（小白版）.md
# 清单勾选：docs/go-live-checklist.md

NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# 生产必须关闭开发头，仅信任 Bearer
COSII_TRUST_DEV_HEADER=0

# 与小程序后台一致；Secret 仅放服务器
WECHAT_APPID=wx你的AppID
WECHAT_SECRET=在此填写AppSecret切勿提交仓库

# 至少 16 字符随机串
COSII_SESSION_SECRET=请替换为至少16位随机字符串

# SQLite（二选一或按文档）
DATA_DIR=/var/lib/cosii
# DB_PATH=/var/lib/cosii/app.db

# 同城核销（生产建议强随机，与开发环境不同）
LOCAL_CODE_PEPPER=请替换为强随机串

# 可选：结构化访问日志
# STRUCTURED_ACCESS_LOG=1
